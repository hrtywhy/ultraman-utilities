# Copy this file to .env and fill in your OWN, freshly-rotated API keys.
# .env is gitignored — never commit real keys.
# Every value here is read only by vite.config.ts, server-side. The
# browser never sees these; it only calls relative /api/* paths.

VT_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
IPQS_API_KEY=
APIVOID_API_KEY=
CRIMINALIP_API_KEY=
PULSEDIVE_API_KEY=
MALTIVERSE_API_KEY=
SHODAN_API_KEY=

# Proxied and ready, but no UI tool consumes these yet:
MXTOOLBOX_API_KEY=
CENSYS_API_KEY_BASE64=
ROSTI_API_KEY=
ABUSECH_API_KEY=
