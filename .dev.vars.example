# For LOCAL testing of the Cloudflare Pages Function only (via `wrangler pages dev`).
# Copy to .dev.vars and fill in your own keys. .dev.vars is gitignored.
# This is separate from .env, which is used by `npm run dev` (the Vite proxy).
# In production, don't use a file at all — set these as encrypted secrets in
# the Cloudflare Pages dashboard (Settings > Environment variables).

VT_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
IPQS_API_KEY=
APIVOID_API_KEY=
CRIMINALIP_API_KEY=
PULSEDIVE_API_KEY=
MALTIVERSE_API_KEY=
SHODAN_API_KEY=
MXTOOLBOX_API_KEY=
CENSYS_API_KEY_BASE64=
ROSTI_API_KEY=
ABUSECH_API_KEY=
